NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/hospital_queue
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
# Comma-separated origins allowed for REST CORS + Socket.IO (browser clients)
CLIENT_ORIGIN=http://localhost:5173

# Optional: enables POST /api/bootstrap/admin-user with header X-Bootstrap-Key
INTERNAL_BOOTSTRAP_KEY=
